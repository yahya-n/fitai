# ═══════════════════════════════════════
# FitAI — Environment Variables
# ═══════════════════════════════════════
# Copy to .env and fill in your values

# OpenRouter API key (required for AI features)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Flask secret key (change in production!)
SECRET_KEY=change-this-to-a-random-string-in-production

# JWT secret for token signing (change in production!)
JWT_SECRET=change-this-to-a-different-random-string

# Google OAuth 2.0 Client ID (optional — enables Google Sign-In)
# Get yours at: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add http://localhost:5000/auth/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Database URL (default: SQLite in project directory)
# DATABASE_URL=sqlite:///fitai.db
